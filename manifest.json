{
  "manifest_version": 3,
  "name": "Screeps SC",
  "description": "Extended browser functionality to the game Screeps",
  "version": "2.0",
  "permissions": [
    "storage",
    "tabs",
    "webRequest",
    "scripting"
  ],
  "host_permissions": [
    "*://screeps.com/*",
    "*://*.leagueofautomatednations.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["module.js", "modules/*", "vendor/*"],
      "matches": ["*://screeps.com/*"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_title": "Screeps SC options"
  },
  "options_ui": {
    "page": "options/options.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "screeps-sc@kirk",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
